{
  "name": "qa-portfolio",
  "version": "1.0.0",
  "description": "QA Automation Portfolio - kihyunqa | MCP 5-server integration with Playwright E2E",
  "author": "kihyunqa <kihyun.qa@gmail.com>",
  "license": "MIT",
  "homepage": "https://kihyunqa.github.io/qa-portfolio",
  "repository": {
    "type": "git",
    "url": "https://github.com/kihyunqa/qa-portfolio"
  },
  "scripts": {
    "test": "npx playwright test",
    "test:login": "npx playwright test login.spec.js",
    "test:search": "npx playwright test search.spec.js",
    "test:cart": "npx playwright test cart.spec.js",
    "test:api": "npx playwright test api.spec.js",
    "test:a11y": "npx playwright test accessibility.spec.js",
    "test:perf": "npx playwright test performance.spec.js",
    "test:ui": "npx playwright test --ui",
    "test:headed": "npx playwright test --headed",
    "test:chromium": "npx playwright test --project=chromium",
    "test:firefox": "npx playwright test --project=firefox",
    "test:mobile": "npx playwright test --project=mobile-chrome",
    "report": "npx playwright show-report",
    "install:playwright": "npx playwright install --with-deps"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0"
  },
  "keywords": [
    "qa",
    "automation",
    "playwright",
    "mcp",
    "e2e",
    "testing",
    "portfolio"
  ]
}
